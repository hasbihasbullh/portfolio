# Example environment variables for local development and deployment
# Copy this file to .env (or set real env vars in your hosting provider)

# Resend API key (keep secret)
RESEND_API_KEY=your_resend_api_key_here

# Receiver email address that will receive contact form messages
CONTACT_RECEIVER_EMAIL=you@example.com

# Optional: From address used when sending emails (must be allowed/verified in Resend if required)
RESEND_FROM=no-reply@example.com

# Optional: public URL used to build default sender domain (used when RESEND_FROM not set)
NEXT_PUBLIC_VERCEL_URL=your-deployment-domain.vercel.app

# Notes:
# - Never commit real secrets to git. Add .env to .gitignore.
# - When deploying (Vercel/Netlify), set these variables in the project settings.
