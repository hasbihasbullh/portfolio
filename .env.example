# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# ⚠️ WARNING: DO NOT put actual sensitive data (API keys, passwords) in this file!
# This file is committed to version control. Copy this file to `.env.local`
# to use it for your local development environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SANITY CMS CONFIGURATION
# ------------------------------------------------------------------------------
# These variables are required to connect your frontend to Sanity CMS.
# You can find the Project ID and Dataset in your sanity.config.ts or Sanity Manage Dashboard.
# These keys are safe to expose to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_SANITY_PROJECT_ID="your_sanity_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# ------------------------------------------------------------------------------
# 2. RESEND EMAIL SERVICE CONFIGURATION (CONTACT FORM)
# ------------------------------------------------------------------------------
# RESEND_API_KEY: Your private API key from resend.com (KEEP SECRET!).
RESEND_API_KEY="re_your_api_key_here"

# CONTACT_RECEIVER_EMAIL: The email address where you want to receive messages from your portfolio.
CONTACT_RECEIVER_EMAIL="youremail@example.com"

# RESEND_FROM: The verified domain/email used to send the email (e.g. contact@yourdomain.com).
# Must be verified in Resend dashboard.
RESEND_FROM="contact@yourdomain.com"

# NEXT_PUBLIC_VERCEL_URL: The base URL of your website, used as a fallback sender domain.
NEXT_PUBLIC_VERCEL_URL="yourdomain.com"

# ------------------------------------------------------------------------------
# 3. EXTERNAL INTEGRATIONS (GITHUB, WAKATIME, MONKEYTYPE)
# ------------------------------------------------------------------------------
# GITHUB_USERNAME: Used to fetch your Github repositories and contribution graph.
GITHUB_USERNAME="your_github_username"

# MONKEYTYPE_USERNAME: Used to fetch your typing speed statistics (if applicable).
MONKEYTYPE_USERNAME="your_monkeytype_username"

# WAKATIME_API_KEY: Used to fetch your coding time statistics.
# Keep this secret as it provides access to your WakaTime account data.
WAKATIME_API_KEY="waka_your_api_key_here"
